rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{eventId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly([
          'title',
          'description',
          'timezone',
          'locationName',
          'locationUrl',
          'locationLat',
          'locationLng',
          'durationMinutes',
          'slots',
          'createdAt'
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 2000 &&
        request.resource.data.timezone is string &&
        request.resource.data.timezone.size() > 0 &&
        request.resource.data.timezone.size() <= 80 &&
        request.resource.data.locationName is string &&
        request.resource.data.locationName.size() <= 200 &&
        request.resource.data.locationUrl is string &&
        request.resource.data.locationUrl.size() <= 1000 &&
        (request.resource.data.locationLat == null || request.resource.data.locationLat is number) &&
        (request.resource.data.locationLng == null || request.resource.data.locationLng is number) &&
        request.resource.data.durationMinutes is number &&
        request.resource.data.durationMinutes >= 15 &&
        request.resource.data.durationMinutes <= 1440 &&
        request.resource.data.slots is list &&
        request.resource.data.slots.size() > 0 &&
        request.resource.data.slots.size() <= 100;
      allow update, delete: if false;

      match /responses/{responseId} {
        allow read: if true;
        allow create, update: if
          request.resource.data.keys().hasOnly([
            'name',
            'normalizedName',
            'selectedSlotIds',
            'submittedAt',
            'updatedAt'
          ]) &&
          request.resource.data.name is string &&
          request.resource.data.name.size() > 0 &&
          request.resource.data.name.size() <= 80 &&
          request.resource.data.normalizedName is string &&
          request.resource.data.normalizedName == responseId &&
          request.resource.data.selectedSlotIds is list &&
          request.resource.data.selectedSlotIds.size() > 0 &&
          request.resource.data.selectedSlotIds.size() <= 100;
        allow delete: if false;
      }
    }
  }
}
